## 3) Frontend — use-case isolado (sem React)
```ts
// apps/web/features/leads/use-cases/__tests__/list-leads.use-case.spec.ts
import { buildListLeadsQuery } from '../list-leads.use-case'

// Testar a lógica sem montar componente
describe('buildListLeadsQuery', () => {
  it('gera queryKey correta com filtros', () => {
    const query = buildListLeadsQuery(2, 'João')
    expect(query.queryKey).toEqual(['leads', { page: 2, limit: 20, search: 'João' }])
  })

  it('usa staleTime de 60s', () => {
    const query = buildListLeadsQuery(1, '')
    expect(query.staleTime).toBe(60_000)
  })
})
```

