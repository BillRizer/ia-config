## Frontend

### Hook genérico de paginação
```ts
// apps/web/lib/hooks/use-paginated-query.ts
import { useQuery, keepPreviousData } from '@tanstack/react-query'
import type { PaginatedResponse } from '@repo/shared'

export function usePaginatedQuery<T>(
  key: string,
  fetcher: (p: { page: number; limit: number } & Record<string, unknown>) => Promise<PaginatedResponse<T>>,
  options: { page: number; limit?: number; filters?: Record<string, unknown> },
) {
  const { page, limit = 20, filters = {} } = options
  return useQuery({
    queryKey: [key, { page, limit, ...filters }],
    queryFn: () => fetcher({ page, limit, ...filters }),
    placeholderData: keepPreviousData, // sem flash entre páginas
  })
}
```

### Camada de API (tipada)
```ts
// apps/web/lib/api/leads.ts
export async function listLeads(params: {
  page?: number; limit?: number; search?: string
}): Promise<PaginatedResponse<Lead>> {
  const q = new URLSearchParams(
    Object.entries(params).filter(([, v]) => v !== undefined).map(([k, v]) => [k, String(v)])
  )
  return apiJson<PaginatedResponse<Lead>>(`/leads?${q}`)
}
```

### Uso em componente
```tsx
// Separar use-case do hook — mais testável
// apps/web/features/leads/use-cases/list-leads.use-case.ts
export function useListLeadsUseCase(page: number, search: string) {
  return usePaginatedQuery('leads', listLeads, { page, filters: { search } })
}

// apps/web/features/leads/LeadsContainer.tsx
export function LeadsContainer() {
