# Paginação — Contrato Padrão

## Tipo compartilhado (packages/shared)
```ts
// packages/shared/src/types/paginated-response.ts
export interface PaginatedResponse<T> {
  data: T[]
  meta: {
    total: number
    page: number
    limit: number
    totalPages: number
  }
}
```

---

## API

### DTO base (Zod)
```ts
// apps/api/src/common/dto/pagination.dto.ts
import { z } from 'zod'
import { createZodDto } from 'nestjs-zod'

export const PaginationSchema = z.object({
  page: z.coerce.number().int().min(1).default(1),
  limit: z.coerce.number().int().min(1).max(100).default(20),
  order: z.enum(['ASC', 'DESC']).default('DESC'),
})
export class PaginationDto extends createZodDto(PaginationSchema) {}
export type PaginationInput = z.infer<typeof PaginationSchema>
```

### Helper de resposta
```ts
// apps/api/src/common/helpers/paginate.ts
export function paginatedResponse<T>(
  data: T[],
  total: number,
  page: number,
  limit: number,
): PaginatedResponse<T> {
  return { data, meta: { total, page, limit, totalPages: Math.ceil(total / limit) } }
}
```

### Uso no repositório
```ts
// QueryBuilder + getManyAndCount() — nunca duas queries separadas
const [data, total] = await qb
  .skip((page - 1) * limit)
  .take(Math.min(limit, 100))
  .getManyAndCount()
return { data, total }
```

### Uso no controller
```ts
@Get()
async list(@Query() filters: FilterLeadsDto) {
  const { data, total } = await this.listLeads.execute(filters)
  return paginatedResponse(data.map(toResponseDto), total, filters.page, filters.limit)
}
```

### Status codes
| Ação | Status | Body |
|---|---|---|
| Lista paginada | 200 | `PaginatedResponse<T>` |
| Detalhe | 200 | `T` |
| Criação | 201 | `T` |
| Update | 200 | `T` |
| Delete | 204 | — |
| Não encontrado | 404 | `ApiErrorResponse` |
| Validação | 400 | `ApiErrorResponse` |

