## 3) Repositório — QueryBuilder obrigatório para queries complexas
```ts
// apps/api/src/leads/lead.repository.ts
@Injectable()
export class LeadRepository implements ILeadRepository {
  constructor(
    @InjectRepository(LeadEntity)
    private readonly repo: Repository<LeadEntity>,
  ) {}

  // Queries simples: find/findOne OK
  async findByEmail(email: string): Promise<LeadEntity | null> {
    return this.repo.findOne({ where: { email } })
  }

  async getByIdOrFail(id: string): Promise<LeadEntity> {
    const lead = await this.repo.findOne({ where: { id } })
    if (!lead) throw new EntityNotFoundError(`Lead ${id} não encontrado`)
    return lead
  }

  // Queries complexas: sempre QueryBuilder no repositório
  async listWithFilters(input: FilterLeadsInput): Promise<[LeadEntity[], number]> {
    const { page, limit, search, status, order } = input
    const skip = (page - 1) * Math.min(limit, 100)

    const qb = this.repo.createQueryBuilder('lead')
      .select(['lead.id', 'lead.name', 'lead.email', 'lead.status', 'lead.createdAt'])
      .leftJoin('lead.opportunities', 'opp')
      .addSelect(['opp.id', 'opp.status'])

    if (search) {
      qb.andWhere('(lead.name ILIKE :search OR lead.email ILIKE :search)', {
        search: `%${search}%`,
      })
    }
    if (status) qb.andWhere('lead.status = :status', { status })

    return qb
      .orderBy('lead.created_at', order)
      .skip(skip)
      .take(Math.min(limit, 100))
      .getManyAndCount()
  }

  async save(lead: LeadEntity): Promise<LeadEntity> {
    return this.repo.save(lead)
  }
}
```

**Interface em packages/domain:**
```ts
// packages/domain/src/repositories/lead.repository.interface.ts
export interface ILeadRepository {
  findByEmail(email: string): Promise<LeadEntity | null>
  getByIdOrFail(id: string): Promise<LeadEntity>
  listWithFilters(input: FilterLeadsInput): Promise<[LeadEntity[], number]>
  save(lead: LeadEntity): Promise<LeadEntity>
}
```

