## 2) Controller fino
```ts
@Controller('leads')
export class LeadsController {
  constructor(private readonly createLead: CreateLeadUseCase) {}

  @Post()
  async create(@Body() dto: CreateLeadDto) {
    return this.mapErrors(() => this.createLead.execute(dto))
  }

  @Get()
  async list(@Query() filters: FilterLeadsDto) {
    const result = await this.mapErrors(() => this.listLeads.execute(filters))
    return paginatedResponse(result.data, result.total, filters.page, filters.limit)
  }

  private async mapErrors<T>(fn: () => Promise<T>): Promise<T> {
    try {
      return await fn()
    } catch (err) {
      if (err instanceof EntityNotFoundError) throw new NotFoundException(err.message)
      if (err instanceof BusinessRuleViolation) throw new UnprocessableEntityException(err.message)
      throw err
    }
  }
}
```

