## Exception Filter global
```ts
// apps/api/src/common/filters/http-exception.filter.ts
@Catch()
export class GlobalExceptionFilter implements ExceptionFilter {
  private readonly logger = new Logger('ExceptionFilter')

  catch(exception: unknown, host: ArgumentsHost) {
    const ctx = host.switchToHttp()
    const res = ctx.getResponse<Response>()
    const req = ctx.getRequest<Request>()

    const { status, body } = this.normalize(exception)

    if (status >= 500) {
      this.logger.error(
        `${req.method} ${req.url} → ${status}`,
        exception instanceof Error ? exception.stack : String(exception),
      )
    }

    res.status(status).json({
      ...body,
      timestamp: new Date().toISOString(),
      path: req.url,
    })
  }

  private normalize(ex: unknown): { status: number; body: object } {
    if (ex instanceof HttpException) {
      const status = ex.getStatus()
      const raw = ex.getResponse()
      const body = typeof raw === 'object' && raw !== null ? raw : { message: raw }
      return { status, body: { statusCode: status, ...body } }
    }
    return {
      status: 500,
      body: { statusCode: 500, error: 'INTERNAL_ERROR', message: 'Erro interno inesperado' },
    }
  }
}
// Registrar em main.ts: app.useGlobalFilters(new GlobalExceptionFilter())
```

