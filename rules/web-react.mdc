## 3) Use-case isolado do hook (testável)
```ts
// features/leads/use-cases/list-leads.use-case.ts  ← lógica pura, testável sem React
export function buildListLeadsQuery(page: number, search: string, limit = 20) {
  return {
    queryKey: ['leads', { page, limit, search }],
    queryFn: () => listLeads({ page, limit, search }),
    placeholderData: keepPreviousData,
    staleTime: 60_000,
  }
}

// features/leads/hooks/use-list-leads.ts  ← só integra com React Query
export function useListLeads(page: number, search: string) {
  return useQuery(buildListLeadsQuery(page, search))
}
```

